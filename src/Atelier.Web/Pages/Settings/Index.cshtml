@page
@model Atelier.Web.Pages.Settings.IndexModel

<main>
    <h1>Settings</h1>
    <p>Administrators can bind a waiting Enterprise WeChat identity to an internal account.</p>
    <p>Open this page with <code>?enterpriseWeChatUserId=...</code> to prefill a pending identity.</p>

    <form method="post" asp-page-handler="Bind">
        <label asp-for="Input.EnterpriseWeChatUserId">Enterprise WeChat user</label>
        <input asp-for="Input.EnterpriseWeChatUserId" />

        <label asp-for="Input.UserId">Internal user</label>
        <select asp-for="Input.UserId">
            @foreach (var user in Model.Users)
            {
                <option value="@user.Id">@user.DisplayName</option>
            }
        </select>

        <button type="submit">Bind user</button>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <p>@Model.StatusMessage</p>
    }

    <section>
        <h2>Weekly deadline rule</h2>
        <p>Preview and record an override or disablement for a reporting week.</p>

        <form method="post" asp-page-handler="PreviewWeeklyDeadline">
            <label asp-for="WeeklyDeadlineInput.ReportingWeekStartDate">Reporting week start</label>
            <input asp-for="WeeklyDeadlineInput.ReportingWeekStartDate" />

            <label asp-for="WeeklyDeadlineInput.ConfiguredDeadline">Configured deadline</label>
            <input asp-for="WeeklyDeadlineInput.ConfiguredDeadline" />

            <label asp-for="WeeklyDeadlineInput.OverrideDeadline">Override deadline</label>
            <input asp-for="WeeklyDeadlineInput.OverrideDeadline" />

            <label asp-for="WeeklyDeadlineInput.DeadlineDisabled">Disable deadline</label>
            <input asp-for="WeeklyDeadlineInput.DeadlineDisabled" />

            <button type="submit">Preview deadline</button>
        </form>

        <form method="post" asp-page-handler="ApplyWeeklyDeadline">
            <input type="hidden" asp-for="WeeklyDeadlineInput.ReportingWeekStartDate" />
            <input type="hidden" asp-for="WeeklyDeadlineInput.ConfiguredDeadline" />
            <input type="hidden" asp-for="WeeklyDeadlineInput.OverrideDeadline" />
            <input type="hidden" asp-for="WeeklyDeadlineInput.DeadlineDisabled" />
            <button type="submit">Record deadline change</button>
        </form>

        @if (Model.WeeklyDeadlinePreview is not null)
        {
            <p>Planned deadline: @Model.WeeklyDeadlinePreview.PlannedDeadline</p>
            <p>Effective deadline: @Model.WeeklyDeadlinePreview.EffectiveDeadline</p>
            <p>Attributed month: @Model.WeeklyDeadlinePreview.AttributedMonth</p>
        }
    </section>

    <section>
        <h2>Deadline notification preview</h2>
        <p>Preview the in-app notifications that would be sent for the current deadline change.</p>
        <partial name="_NotificationInbox" model="Model.NotificationPreviewEvents" />
    </section>
</main>
